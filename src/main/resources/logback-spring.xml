<?xml version="1.0" encoding="UTF-8"?>

<!-- we have name the file as logback-spring.xml because 
  -->
<configuration>
    <!-- In the logback configuration we mainly use appender and logger/root to configure our logs -->
    <property name="LOG_DIR" value="./logs"/>
    <property name="LOG_FILE_NAME" value="myJournal"/>
    <!-- we are configuring this property to use in the below configuration -->

    <include resource="org/springframework/boot/logging/logback/defaults.xml" />
    <include resource="org/springframework/boot/logging/logback/console-appender.xml" />
    <!-- these are default logging pattern which is used by spring by default, if you want use this we have mention include them as resource.
    use the reference as "CONOSLE" for console logs.
    use ${FILE_LOG_PATTERN} as pattern for any encoder in any appender
    -->

    <!-- <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH-mm-ss} [%thread] %highlight(%-5level) %logger{36} - %msg%n</pattern>
        </encoder>
    </appender> -->
    <!-- use the above appender for custom console logs -->

    <appender name="RollingFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${LOG_FILE_NAME}.log</file>
        <!-- first every log is written here once the size is reached or new executing is started it will roll over to the next file and makes this file clean again. -->
        
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archived/${LOG_FILE_NAME}.%d{yyyy-MM-dd HH:mm}.%i.log</fileNamePattern>
            <maxFileSize>100KB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <!-- rolling polocy is configured above -->

        <!-- <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder> -->
        <!-- this the custom pattern for the rolling file logs. -->

        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
        </encoder>
        <!-- here we are using the default pattern which the spring uses -->
    </appender>
    <!-- this appender is used for creating logs in a particular folder. where logs files are created based on size and rolled files. -->
    <!-- if you don't want rolling feature we use just "FileAppender" in the class -->

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
    <!-- here we have provided the level on the root file and where it should print the logs by providing its appender-reference. -->

    <!-- <logger name="com.jkv.myJournal" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="RollingFile"/>
    </logger> -->
    <!-- here we have provided the level on the custom package and where it should print the logs by providing its appender-reference. 
    the additivity is used here because the we have already mentioned CONSOLE appender in root and here.
    so it will print twice in the console. so to prevent it we use this additivity.
    or we have no include CONSOLE appender here, since it is already mentioned in root but only info log will print since root is set to INFO.
    -->

    <springProfile name="dev">
        <logger name="com.jkv.myJournal" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
    </springProfile>

    <springProfile name="prod, production">
        <logger name="com.jkv.myJournal" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="RollingFile"/>
        </logger>
    </springProfile>

    <!-- so by using the springProfile we can config how the logs should behave based on the profiles. -->

    <!-- <appender name="AsyncFile" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="RollingFile" />
        <queueSize>500</queueSize>
        <discardingThreshold>0</discardingThreshold>
    </appender>

    <root level="INFO">
        <appender-ref ref="Console" />
        <appender-ref ref="AsyncFile" />
    </root> -->
    <!-- so basically while printing the log the application is stop. to make sure the application is not waiting for the logs to print.
    we use AsyncAppender like above.
    -->

    <!-- <appender name="JsonConsole" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.JsonEncoder" />
    </appender> -->
    <!-- this is used for providing logs in json format for aws services if needed. -->

    <!-- <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level> </filter>
        <encoder>...</encoder>
    </appender> -->
    <!-- this appender will filter out the logs which are less severe than WARN level. so only WARN and ERROR logs will print -->

    <!-- <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
        <evaluator>
            <expression>return message.contains("password");</expression>
        </evaluator>
        <OnMismatch>NEUTRAL</OnMismatch>
        <OnMatch>DENY</OnMatch>
    </filter> -->
    <!-- basically this filter looks for the keyword "password" and provide those logs only when OnMatch is "ACCEPT". it will not print the logs if is set to "DENY"-->

</configuration>